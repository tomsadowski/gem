

init_path  = "~/.config/nvim/readme.md"

layout = {
  x_page = 2,
  y_page = 2,
  x_text = 2,
  y_text = 2,
  background = "101010",
  border = "c0c0c0",
  banner = "c0c0c0",
  text = "c0c0c0",
}

keys = {
  global   = "g",
  msg_view = "m",
  tab_view = "t",
  load_usr = "l",
  move_up     = "o",
  move_down   = "i",
  move_left   = "e",
  move_right  = "n",
  cycle_left  = "left",
  cycle_right = "right",
  inspect     = "space",
  delete_tab  = "d",
  new_tab    = "t",
  yes    = "y",
  no     = "n",
  ack    = "enter",
  cancel = "esc",
}
